# ============================================================
# Neo4j AuraDB — Credenciales de conexión
# ============================================================
# 1. Ir a https://console.neo4j.io e iniciar sesión
# 2. Crear una instancia AuraDB Free (no requiere tarjeta)
# 3. Copiar la URI de conexión y la contraseña generada
# ============================================================

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Puerto del servidor Express (por defecto 3001)
PORT=3001
